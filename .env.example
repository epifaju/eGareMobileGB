# Copier vers .env (non versionné) : copy .env.example .env

# PostgreSQL 16 + PostGIS (port machine → conteneur 5432)
# Si 5433 est pris, mets un autre port libre, ex. POSTGRES_PORT=15432
POSTGRES_USER=gare
POSTGRES_PASSWORD=gare_dev_secret
POSTGRES_DB=garemobilegb
POSTGRES_PORT=5433

# Redis 7
REDIS_PORT=6379

# MinIO (API S3-compatible + console web)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Backend Spring Boot (dossier backend/) ---
# SPRING_PROFILES_ACTIVE=dev
# JWT_SECRET=remplacer-par-une-cle-32-octets-minimum-en-production
# SEED_ADMIN_PASSWORD=mot-de-passe-admin-dev

# --- Mobile Expo (fichier mobile/.env) ---
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8080
